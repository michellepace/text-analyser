{
    // General editor settings
    "window.commandCenter": true,   // search box at top of window
    "editor.colorDecorators": true, // show colour pickers in code

    // Hide generated cache/venv dirs from the Explorer
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true
    },

    // 🐍 UV PYTHON ENVIRONMENT
    // `uv sync` creates .venv/ → IDE auto-detects the interpreter below.
    // uv convention: don't activate the venv — run commands via `uv run <cmd>`
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": false, // don't auto-activate; use `uv run`

    // 🐍 Ruff: Python lint & format — editor behaviour only.
    // The rules themselves live in pyproject.toml; type-checking via Pylance/Pyright.
    "ruff.nativeServer": "on",  // faster Rust-based language server
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",         // apply Ruff autofixes on save
            "source.organizeImports.ruff": "explicit" // sort & prune imports on save
        }
    },

    // 📝 Markdownlint: Markdown linting (matches CodeRabbit's checks)
    "[markdown]": {
        "editor.codeActionsOnSave": {
            "source.fixAll.markdownlint": "explicit"
        }
    },
}
