{
    "recommendations": [
        "ms-python.python",           // core Python: debugging, Test Explorer, venv integration
        "ms-python.debugpy",          // Python debugger (breakpoints, stepping)
        "charliermarsh.ruff",         // linter & formatter (Astral, same family as uv)
        "ms-python.vscode-pylance",   // (vscode) language server: autocomplete, hover, go-to-definition
        "tamasfe.even-better-toml",   // TOML support for pyproject.toml (highlighting, validation)
        "davidanson.vscode-markdownlint",  // Markdown linter (same tool CodeRabbit uses)

        // Notes:
        // 1. ms-python.python expects to manage the venv, but here uv owns it (`uv sync`)
        // 2. Ruff doesn't type-check — Pyright/Pylance does (and overlaps some Ruff checks);
        //    configure both in pyproject.toml
    ]
}
